# ── vLLM ──
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=cyankiwi/Qwen3.5-4B-AWQ-4bit
EMBED_BASE_URL=http://localhost:8001/v1
EMBED_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5

# ── LLM params ──
LLM_TEMPERATURE=0.25
LLM_MAX_TOKENS=2048
SYNTH_MAX_TOKENS=4096

# ── Search ──
SEARCH_BACKEND=duckduckgo
SEARCH_FALLBACK=1
SEARCH_PER_QUERY=8
SEARCH_RECENCY_BOOST=0.05
SEARCH_HOST_DEDUP=1

# ── Fetch ──
MAX_PAGE_CHARS=10000
FETCH_TIMEOUT=15
FETCH_CONCURRENCY=5

# ── Sub-agents ──
MAX_SUB_TASKS=5
DEFAULT_PAGES_PER_TASK=5
MIN_PAGES_PER_TASK=2
MAX_PAGES_PER_TASK=8

# ── Iteration ──
MAX_ITERATIONS=5
MIN_FACTS_FOR_COVERAGE=20

# ── Memory ──
MEMORY_DIR=advanced_memory
MEMORY_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.35
MEMORY_MIN_CHARS=200
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# ── Dedup ──
FACT_DEDUP_THRESHOLD=0.85

# ── Tracing (optional) ──
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lite-deep-research